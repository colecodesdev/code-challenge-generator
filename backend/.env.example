OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional: cap on completion length per challenge. Default 800. Raise if
# hard-difficulty challenges hit "AI response was truncated".
OPENAI_MAX_TOKENS=

# Optional: enable Clerk auth (local dev works without this)
CLERK_SECRET_KEY=
JWT_KEY=

# Optional: comma-separated list of allowed CORS origins.
# Defaults to http://localhost:5173,http://localhost:5174 when unset.
# Production: set to the CloudFront URL, e.g. https://d1tsfobuj7g5p2.cloudfront.net
CORS_ORIGINS=